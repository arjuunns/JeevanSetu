# ─────────────────────────────────────────────────────────────
# JeevanSetu Environment Variables (Template)
# Copy to .env and fill in real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:3000
LOG_LEVEL=debug

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://jeevansetu:jeevansetu@localhost:5432/jeevansetu?schema=public

# Redis (cache + pub/sub)
REDIS_URL=redis://localhost:6379

# Gemini / AI stack
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_TRIAGE_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Pinecone (vector DB for RAG (Retriveal aug gener))
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=jeevansetu-guidelines

# Neo4j (graph DB for routing)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=jeevansetu

# Clerk (auth)
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret

# AWS S3 (document storage)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=jeevansetu-documents

# Notifications
RESEND_API_KEY=your_resend_api_key_here
NOTIFICATION_FROM_EMAIL=alerts@yourdomain.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=your_twilio_phone_number

# Observability
SENTRY_DSN=your_sentry_dsn_here
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
